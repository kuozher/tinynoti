<Window x:Class="TinyNoti.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="394"
        Height="{Binding OverlayHeight}"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="RoundIconButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#E6F8FAFC" />
            <Setter Property="BorderBrush" Value="#CCD8E0EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FFFFFFFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="Foreground" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#E2E8F0" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#CBD5E1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="#88F8FAFC" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#66D8E0EC" />
                                <Setter Property="Foreground" Value="#64748B" />
                                <Setter Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderTextButton" TargetType="Button">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Background" Value="#B8F8FAFC" />
            <Setter Property="BorderBrush" Value="#88D8E0EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#3B6B9A" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#F8FAFC" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#D8E0EC" />
                                <Setter Property="Foreground" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#E2E8F0" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#CBD5E1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="OverlayRoot" Width="384">
        <Grid.RenderTransform>
            <TranslateTransform />
        </Grid.RenderTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel x:Name="HeaderActions"
                    Grid.Row="0"
                    Orientation="Horizontal"
                    HorizontalAlignment="{Binding HeaderHorizontalAlignment}"
                    Margin="{Binding HeaderMargin}"
                    Visibility="{Binding IsOverlayChromeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Button x:Name="RemoveAllButton"
                    Style="{StaticResource HeaderTextButton}"
                    Content="Clear all"
                    ToolTip="Clear all notifications"
                    Click="ClearAll_Click" />
            <Button x:Name="HideForNowButton"
                    Style="{StaticResource RoundIconButton}"
                    Margin="6,0,0,0"
                    ToolTip="Hide for now"
                    Click="HideOverlay_Click">
                <Path x:Name="HideArrow"
                      Width="7"
                      Height="12"
                      IsHitTestVisible="False"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="1.8"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Stretch="Uniform"
                      Data="M 1 1 L 6 6 L 1 11" />
            </Button>
        </StackPanel>

        <Grid Grid.Row="1">
            <Border x:Name="GlassPanel"
                    BorderBrush="#4CF8FAFC"
                    BorderThickness="0,1,1,1"
                    CornerRadius="{Binding GlassCornerRadius}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#00F8FAFC" Offset="0" />
                        <GradientStop Color="#28F8FAFC" Offset="0.08" />
                        <GradientStop Color="#52F8FAFC" Offset="0.22" />
                        <GradientStop Color="#5EF8FAFC" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <ScrollViewer x:Name="CardsScrollViewer"
                          MaxHeight="{Binding MaxListHeight}"
                          Margin="0,10,0,10"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalFirst"
                          CanContentScroll="False">
                <Grid MinHeight="{Binding ContentMinHeight}">
                    <ItemsControl x:Name="CardsItems"
                                  ItemsSource="{Binding Cards}"
                                  VerticalAlignment="{Binding CardsVerticalAlignment}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Opacity" Value="0" />
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="10" />
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="1"
                                                                 Duration="0:0:0.24">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                 To="0"
                                                                 Duration="0:0:0.28">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="360"
                                        MinHeight="112"
                                        Margin="12,0,12,8"
                                        Padding="12"
                                        Background="#FFFFFF"
                                        BorderBrush="#D8E0EC"
                                        BorderThickness="1"
                                        CornerRadius="11"
                                        RenderTransformOrigin="0.5,0.5"
                                        MouseLeftButtonUp="Card_MouseLeftButtonUp">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="28" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding AppName}"
                                                           Foreground="#2563EB"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding TimeText}"
                                                           Foreground="#64748B"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                Style="{StaticResource RoundIconButton}"
                                                Click="Dismiss_Click"
                                                ToolTip="Dismiss notification">
                                                <Path Width="10"
                                                      Height="10"
                                                      IsHitTestVisible="False"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      StrokeThickness="1.8"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      Data="M 1 1 L 9 9 M 9 1 L 1 9" />
                                            </Button>
                                        </Grid>

                                        <Grid Grid.Row="1" Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Width="64"
                                                    Height="64"
                                                    CornerRadius="10"
                                                    ClipToBounds="True"
                                                    Background="#EEF2F7"
                                                    VerticalAlignment="Top">
                                                <Image Source="{Binding AppIconUri}" Stretch="UniformToFill" />
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="#111827"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           LineHeight="18"
                                                           MaxHeight="18" />
                                                <TextBlock Text="{Binding Body}"
                                                           Foreground="#334155"
                                                           Margin="0,4,0,0"
                                                           TextWrapping="Wrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           LineHeight="18"
                                                           MaxHeight="54" />
                                                <Border Margin="0,8,0,0"
                                                        Width="96"
                                                        Height="64"
                                                        HorizontalAlignment="Left"
                                                        CornerRadius="8"
                                                        ClipToBounds="True"
                                                        Visibility="{Binding ImageUri, Converter={StaticResource NullToVisibilityConverter}}">
                                                    <Image Source="{Binding ImageUri}" Stretch="UniformToFill" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Width="360"
                            MinHeight="112"
                            Margin="12,0,12,0"
                            Padding="20"
                            Background="#F8FAFC"
                            BorderBrush="#D8E0EC"
                            BorderThickness="1"
                            CornerRadius="11"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding EmptyStateVisibility}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="No recent notifications"
                                       Foreground="#334155"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center" />
                            <TextBlock Text="New notifications will appear here when they arrive."
                                       Foreground="#64748B"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <Rectangle x:Name="BottomFade"
                       Height="92"
                       VerticalAlignment="Bottom"
                       IsHitTestVisible="False"
                       RadiusX="0"
                       RadiusY="0"
                       Visibility="{Binding BottomFadeVisibility}">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00F8FAFC" Offset="0" />
                        <GradientStop Color="#A8F8FAFC" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>
    </Grid>
</Window>
